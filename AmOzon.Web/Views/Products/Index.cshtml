@model List<AmOzon.Contracts.Responses.ProductsResponse>

@{
    ViewData["Title"] = "Product Catalog";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3">Product Catalog</h1>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary btn-sm" asp-controller="Products" asp-action="MyProducts">My products</a>
            <a class="btn btn-primary btn-sm" asp-controller="Products" asp-action="Create">Add product</a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">No products yet.</div>
    }
    else
    {
        <div class="row">
            @foreach (var product in Model.Where(x => !x.IsDeleted))
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted flex-grow-1">@product.Description</p>
                            <p class="text-success fw-bold mb-1">@product.Price</p>
                            <small class="text-muted">Stock: @product.StockQuantity</small>
                            <div class="mt-3 d-flex gap-2">
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">Details</a>
                                <form asp-controller="Cart" asp-action="Add" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <button type="submit" class="btn btn-sm btn-primary">Add to cart</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>