@model ProductDetailsPageViewModel

@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-4">
    <a asp-controller="Products" asp-action="Index" class="btn btn-link p-0 mb-3">Back to catalog</a>
    <div class="card">
        <div class="card-body">
            <h2 class="h4">@Model.Product.Name</h2>
            <p class="text-muted">@Model.Product.Description</p>
            <div class="mb-3">
                <span class="fw-bold text-success">@Model.Product.Price</span>
                <span class="ms-3 text-muted">Stock: @Model.Product.StockQuantity</span>
            </div>

            <div class="d-flex gap-2">
                <form asp-controller="Cart" asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Product.Id" />
                    <button type="submit" class="btn btn-primary">Add to cart</button>
                </form>

                @if (Model.CanManageProduct)
                {
                    <a asp-controller="Products" asp-action="Edit" asp-route-id="@Model.Product.Id" class="btn btn-outline-secondary">Edit</a>
                }
            </div>
        </div>
    </div>
</div>