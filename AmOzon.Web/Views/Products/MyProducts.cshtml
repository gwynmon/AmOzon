@model List<AmOzon.Contracts.Responses.ProductsResponse>

@{
    ViewData["Title"] = "My Products";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0">My Products</h2>
        <a asp-controller="Products" asp-action="Create" class="btn btn-primary">Create product</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">You do not have products yet.</div>
    }
    else
    {
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.Name</td>
                        <td>@product.Price</td>
                        <td>@product.StockQuantity</td>
                        <td>
                            @if (product.IsDeleted)
                            {
                                <span class="badge bg-secondary">Archived</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-controller="Products" asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <form asp-controller="Products" asp-action="ToggleDeleted" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@product.Id" />
                                <input type="hidden" name="isDeleted" value="@product.IsDeleted.ToString().ToLowerInvariant()" />
                                <button class="btn btn-sm @(product.IsDeleted ? "btn-outline-success" : "btn-outline-danger")" type="submit">
                                    @(product.IsDeleted ? "Restore" : "Archive")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
