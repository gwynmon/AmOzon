@model List<AmOzon.Contracts.Responses.SellerResponse>

@{
    ViewData["Title"] = "Sellers";
}

<div class="container mt-4">
    <h2 class="h4 mb-3">Sellers</h2>
    @if (!Model.Any())
    {
        <div class="alert alert-info">No sellers found.</div>
    }
    else
    {
        <table class="table">
            <thead>
            <tr>
                <th>Seller ID</th>
                <th>User ID</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var seller in Model)
            {
                <tr>
                    <td><code>@seller.Id</code></td>
                    <td><code>@seller.UserId</code></td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>